{
  "name": "@leomaradan/sd-tools",
  "version": "1.2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Leomaradan/sd-tools.git"
  },
  "dependencies": {
    "@inquirer/prompts": "^5.0.4",
    "axios": "^1.7.2",
    "configstore": "^6.0.0",
    "dompurify": "^3.1.5",
    "htmlparser2": "^9.1.0",
    "image-size": "^1.1.1",
    "jsonschema": "^1.4.1",
    "png-chunk-text": "^1.0.0",
    "png-chunks-extract": "^1.0.0",
    "table": "^6.8.2",
    "xdg-basedir": "^5.1.0",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@babel/core": "^7.24.6",
    "@babel/preset-env": "^7.24.6",
    "@babel/preset-typescript": "^7.24.6",
    "@eslint/js": "^10.0.1",
    "@types/configstore": "^6.0.2",
    "@types/dompurify": "^3",
    "@types/eslint__js": "^8.42.3",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.12.13",
    "@types/png-chunk-text": "^1.0.3",
    "@types/png-chunks-extract": "^1.0.2",
    "@types/yargs": "^17.0.32",
    "babel-jest": "^29.7.0",
    "esbuild": "^0.21.4",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^28.14.0",
    "eslint-plugin-only-warn": "^1.2.1",
    "eslint-plugin-oxlint": "^1.51.0",
    "eslint-plugin-perfectionist": "^5.6.0",
    "eslint-plugin-sonarjs": "^4.0.0",
    "husky": "^9.0.11",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.5",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "oxlint-tsgolint": "^0.16.0",
    "pinst": "^3.0.0",
    "prettier": "^3.2.5",
    "typescript": "6.0.0-beta",
    "typescript-eslint": "^8.56.1",
    "typescript-json-schema": "^0.63.0"
  },
  "bin": "sd-tools.cjs",
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "yarn lint:fix",
      "oxfmt --no-error-on-unmatched-pattern"
    ],
    "*": [
      "oxfmt --no-error-on-unmatched-pattern"
    ]
  },
  "main": "./dist/index.cjs",
  "exports": {
    "./package.json": "./package.json",
    "./schema/queue.json": "./schema/queue.json",
    "./schema/rename.json": "./schema/rename.json",
    ".": {
      "require": {
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist/index.cjs",
    "sd-tools.cjs"
  ],
  "type": "module",
  "packageManager": "yarn@4.2.2",
  "scripts": {
    "build": "yarn schema && node ./esbuild.mjs",
    "build:prod": "yarn schema && NODE_ENV=production node ./esbuild.mjs",
    "watch": "yarn schema && NODE_ENV=watch node ./esbuild.mjs",
    "start": "node build/index.cjs",
    "test": "jest --coverage --detectOpenHandles",
    "lint": "oxlint --type-aware && eslint --report-unused-disable-directives",
    "lint:fix": "oxlint --type-aware --fix && eslint --report-unused-disable-directives --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "schema": "yarn schema:queue && yarn schema:rename",
    "schema:queue": "typescript-json-schema ./tsconfig.json IPrompts --required --noExtraProps --out schema/queue.json --titles --useTypeOfKeyword",
    "schema:rename": "typescript-json-schema ./tsconfig.json IRenameConfig --required --noExtraProps --out schema/rename.json --titles --useTypeOfKeyword",
    "postinstall": "husky install",
    "prepack": "pinst --disable",
    "postpack": "pinst --enable"
  }
}
