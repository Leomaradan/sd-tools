{
  "name": "@leomaradan/sd-tools",
  "version": "1.3.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Leomaradan/sd-tools.git"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.0",
    "axios": "^1.13.6",
    "configstore": "^8.0.0",
    "image-size": "^2.0.2",
    "jsonschema": "^1.5.0",
    "png-chunk-text": "^1.0.0",
    "png-chunks-extract": "^1.0.0",
    "table": "^6.9.0",
    "xdg-basedir": "^5.1.0",
    "yaml": "^2.8.2",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@babel/preset-typescript": "^7.28.5",
    "@eslint/js": "^10.0.1",
    "@jest/globals": "^30.2.0",
    "@types/configstore": "^6.0.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.35",
    "@types/png-chunk-text": "^1.0.3",
    "@types/png-chunks-extract": "^1.0.2",
    "@types/yargs": "^17.0.35",
    "babel-jest": "^30.2.0",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.2",
    "eslint-plugin-jest": "^29.15.0",
    "eslint-plugin-only-warn": "^1.2.1",
    "eslint-plugin-oxlint": "^1.51.0",
    "eslint-plugin-perfectionist": "^5.6.0",
    "eslint-plugin-sonarjs": "^4.0.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "lint-staged": "^16.3.2",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "oxlint-tsgolint": "^0.16.0",
    "typescript": "6.0.0-beta",
    "typescript-eslint": "^8.56.1",
    "typescript-json-schema": "^0.67.1"
  },
  "bin": "./bin/sd-tools",
  "license": "MIT",
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "pnpm lint:fix",
      "oxfmt --no-error-on-unmatched-pattern"
    ],
    "*": [
      "oxfmt --no-error-on-unmatched-pattern"
    ]
  },
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json",
    "./schema/queue.json": "./schema/queue.json",
    "./schema/rename.json": "./schema/rename.json"
  },
  "files": [
    "dist/index.js",
    "bin/sd-tools",
    "schema/queue.json",
    "schema/rename.json"
  ],
  "type": "module",
  "packageManager": "pnpm@10.27.0+sha512.72d699da16b1179c14ba9e64dc71c9a40988cbdc65c264cb0e489db7de917f20dcf4d64d8723625f2969ba52d4b7e2a1170682d9ac2a5dcaeaab732b7e16f04a",
  "scripts": {
    "build": "pnpm schema && node ./esbuild.mjs",
    "build:prod": "pnpm schema && NODE_ENV=production node ./esbuild.mjs",
    "watch": "pnpm schema && NODE_ENV=watch node ./esbuild.mjs",
    "start": "node build/index.js",
    "test": "jest --coverage --detectOpenHandles",
    "lint": "oxlint --type-aware && eslint --report-unused-disable-directives",
    "lint:fix": "oxlint --type-aware --fix && eslint --report-unused-disable-directives --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "schema": "pnpm schema:queue && pnpm schema:rename",
    "schema:queue": "typescript-json-schema ./tsconfig.json IPrompts --required --noExtraProps --out schema/queue.json --titles --useTypeOfKeyword",
    "schema:rename": "typescript-json-schema ./tsconfig.json IRenameConfig --required --noExtraProps --out schema/rename.json --titles --useTypeOfKeyword",
    "prepare": "husky"
  }
}
